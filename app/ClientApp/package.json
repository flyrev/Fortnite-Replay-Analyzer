{
  "name": "fortnite-replay-analyzer",
  "version": "1.0.0",
  "private": true,
  "dependencies": {
    "axios": "^1.13.6",
    "bootstrap": "^5.3.8",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-bootstrap": "^0.26.3",
    "react-router-dom": "^7.5.0",
    "react-scripts": "^5.0.1",
    "reactstrap": "^9.2.3"
  },
  "devDependencies": {
    "ajv": "^8.18.0",
    "cross-env": "^10.1.0",
    "eslint": "^8.57.0",
    "eslint-config-react-app": "^7.0.1",
    "typescript": "^5.9.3"
  },
  "eslintConfig": {
    "extends": "react-app"
  },
  "scripts": {
    "start": "react-scripts start",
    "build": "react-scripts build",
    "test": "cross-env CI=true react-scripts test --env=jsdom",
    "eject": "react-scripts eject",
    "lint": "eslint ./src/"
  },
  "jest": {
    "moduleNameMapper": {
      "^react-router-dom$": "<rootDir>/node_modules/react-router-dom/dist/index.js",
      "^react-router$": "<rootDir>/node_modules/react-router/dist/production/index.js",
      "^react-router/dom$": "<rootDir>/node_modules/react-router/dist/production/dom-export.js"
    },
    "transformIgnorePatterns": [
      "node_modules/(?!(axios|react-router|react-router-dom)/)"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
